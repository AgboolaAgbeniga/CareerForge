    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsdom": "^22.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.3",
