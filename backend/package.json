{
  "name": "careerforge-backend",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "description": "Backend API server for CareerForge",
  "main": "src/index.ts",
  "scripts": {
    "start": "concurrently -n api,ai -c blue,magenta \"node dist/index.js\" \"cd ai && .venv\\Scripts\\python -m uvicorn app:app --host 0.0.0.0 --port 8000\"",
    "dev": "concurrently -n api,ai -c blue,magenta \"nodemon\" \"cd ai && .venv\\Scripts\\python -m uvicorn app:app --host 0.0.0.0 --port 8000 --reload\"",
    "dev:api": "nodemon",
    "dev:ai": "cd ai && .venv\\Scripts\\python -m uvicorn app:app --host 0.0.0.0 --port 8000 --reload",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "generate": "drizzle-kit generate:pg",
    "migrate": "drizzle-kit push:pg",
    "test:scraper": "ts-node src/scripts/test-scraper.ts",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.89.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.78.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "file-type": "^22.0.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "http-proxy": "^1.18.1",
    "ioredis": "^5.11.1",
    "jsdom": "^22.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^8.3.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/http-proxy": "^1.17.17",
    "@types/jest": "^29.5.8",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
