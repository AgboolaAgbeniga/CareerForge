# ============================================================
# CareerForge AI Services - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# AI Provider: "nvidia" (primary), "huggingface" (fallback), "local" (dev)
AI_PROVIDER=huggingface

# NVIDIA NIM Configuration (production)
NVIDIA_API_KEY=
NVIDIA_LLM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Hugging Face API Configuration (fallback)
HF_API_KEY=
USE_API_MODELS=true

# AI Service Ports
RESUME_PARSER_PORT=8000
MATCHING_ENGINE_PORT=8001
CAREER_COACH_PORT=8002

# Database (for pgvector embeddings)
DATABASE_URL=

# Redis (caching)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
LOG_LEVEL=INFO
