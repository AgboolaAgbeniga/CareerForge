@echo off
echo Installing missing Tailwind CSS plugins for docs...

cd docs

echo Installing packages...
npm install @tailwindcss/typography @tailwindcss/forms @tailwindcss/aspect-ratio --save-dev

if %ERRORLEVEL% EQU 0 (
    echo.
    echo Packages installed successfully!
    echo.
    echo IMPORTANT: You need to uncomment the plugins in tailwind.config.js
    echo Look for these lines and remove the // comments:
    echo   require('@tailwindcss/typography'),
    echo   require('@tailwindcss/forms'),
    echo   require('@tailwindcss/aspect-ratio'),
    echo.
    echo Then run: npm run dev
) else (
    echo.
    echo Error installing packages. Please run manually:
    echo npm install @tailwindcss/typography @tailwindcss/forms @tailwindcss/aspect-ratio --save-dev
)

pause