# Production Environment Variables for AI Services (Render)
# Copy this file to .env.production and fill in your actual values

# Server Configuration
NODE_ENV=production
PORT=8000

# Database Configuration (Same as backend)
# Get this from your database provider (Supabase, Railway, PlanetScale, etc.)
DATABASE_URL=postgresql://username:password@host:port/database_name

# Hugging Face API Key (Required for AI models)
# Get from: https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model Configuration
# Directory to cache downloaded models
MODEL_CACHE_DIR=/app/models

# Performance Settings
MAX_WORKERS=4
TIMEOUT_SECONDS=30

# Redis Configuration (Optional - for caching)
# REDIS_URL=redis://username:password@host:port

# Logging
LOG_LEVEL=info

# Service Ports (if running individual services)
# RESUME_PARSER_PORT=8000
# MATCHING_ENGINE_PORT=8001
# CAREER_COACH_PORT=8002

# Model Settings
MAX_SEQUENCE_LENGTH=512
BATCH_SIZE=16

# Security Notes:
# - CORS is configured to allow specific origins
# - Update ai/app.py with your frontend domain
# - Models will be cached in MODEL_CACHE_DIR